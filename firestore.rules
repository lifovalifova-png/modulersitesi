rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isUnmodified(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function verifiedEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    // ── admins: kullanıcı sadece kendi admin doc'unu okuyabilir ──
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /ilanlar/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.firmaId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null && (
        isAdmin() ||
        (resource.data.firmaId == request.auth.uid
         && isUnmodified('firmaId')
         && (request.resource.data.status == resource.data.status
             || request.resource.data.status == 'pasif'))
      );
      allow delete: if request.auth != null && (
        resource.data.firmaId == request.auth.uid || isAdmin()
      );
    }

    match /firms/{id} {
      allow read: if resource.data.verified == true
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || (request.auth != null && isAdmin());
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.verified == false
        && !request.resource.data.keys().hasAny(['vergiNo']);
      allow update: if request.auth != null && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid
          && isUnmodified('userId')
          && isUnmodified('verified')
          && isUnmodified('status'))
      );
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ── firmaPrivate: PII (vergiNo) — sadece sahibi ve admin ──
    match /firmaPrivate/{id} {
      allow read: if request.auth != null && (
        isAdmin() ||
        get(/databases/$(database)/documents/firms/$(id)).data.userId == request.auth.uid
      );
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/firms/$(id)).data.userId == request.auth.uid;
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }

    match /teklifler/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.data.firmaId == request.auth.uid ||
        (resource.data.musteri.email != null
         && request.auth.token.email == resource.data.musteri.email
         && verifiedEmail())
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        resource.data.firmaId == request.auth.uid ||
        (resource.data.musteri.email != null
         && request.auth.token.email == resource.data.musteri.email
         && verifiedEmail())
      );
      allow delete: if request.auth != null && isAdmin();
    }

    match /taleplar/{id} {
      allow create: if request.resource.data.keys().hasAll(['kategori','sehir','ad','email','telefon'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 100
        && request.resource.data.telefon is string
        && request.resource.data.telefon.size() > 0
        && request.resource.data.telefon.size() < 20
        && request.resource.data.size() <= 16;
      allow read: if (request.auth != null && isAdmin())
        || (request.auth != null
            && resource.data.email == request.auth.token.email
            && verifiedEmail());
      allow update, delete: if request.auth != null && isAdmin();
    }

    match /quotes/{id} {
      allow create: if request.resource.data.keys().hasAll(['ilanId','musteriAd','musteriEmail','musteriTelefon'])
        && request.resource.data.musteriEmail is string
        && request.resource.data.musteriEmail.size() > 0
        && request.resource.data.musteriEmail.size() < 100
        && request.resource.data.musteriTelefon is string
        && request.resource.data.musteriTelefon.size() > 0
        && request.resource.data.musteriTelefon.size() < 20
        && request.resource.data.size() <= 14;
      allow read: if (request.auth != null && isAdmin())
        || (request.auth != null
            && resource.data.musteriEmail == request.auth.token.email
            && verifiedEmail());
      allow delete: if request.auth != null && isAdmin();
    }

    match /yorumlar/{yorumId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['firmaId','userId','puan'])
        && request.resource.data.firmaId is string
        && request.resource.data.userId == request.auth.uid
        && yorumId == request.resource.data.firmaId + '_' + request.auth.uid
        && request.resource.data.puan is int
        && request.resource.data.puan >= 1
        && request.resource.data.puan <= 5
        && (!('aciklama' in request.resource.data)
            || request.resource.data.aciklama == null
            || (request.resource.data.aciklama is string
                && request.resource.data.aciklama.size() <= 1000))
        && request.resource.data.size() <= 8
        && get(/databases/$(database)/documents/firms/$(request.resource.data.firmaId)).data.userId != request.auth.uid;
      allow update, delete: if request.auth != null && isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ── blog: yayinda kontrolü ──
    match /blog/{docId} {
      allow read: if resource.data.aktif == true || (request.auth != null && isAdmin());
      allow write, delete: if request.auth != null && isAdmin();
    }

    match /blogSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /hakkimizda/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /bildirimler/{id} {
      allow read: if request.auth != null
        && (resource.data.firmaUserId == request.auth.uid || isAdmin());
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    match /geri_bildirimler/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && isAdmin();
    }

    // ── haberler: yayinda kontrolü ──
    match /haberler/{id} {
      allow read: if resource.data.yayinda == true || (request.auth != null && isAdmin());
      allow write: if request.auth != null && isAdmin();
    }

    match /haberKaynaklari/{id} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /etkinlikler/{id} {
      allow read: if true;
      allow create: if request.auth != null && isAdmin();
      allow update, delete: if request.auth != null && isAdmin();
    }

    match /flashDeals/{id} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /whatsappTiklamalari/{id} {
      allow create: if request.resource.data.keys()
          .hasOnly(['firmaId', 'ilanId', 'tarih', 'userAgent'])
        && request.resource.data.firmaId is string
        && request.resource.data.firmaId.size() < 60
        && request.resource.data.tarih == request.time;
      allow read: if request.auth != null && isAdmin();
    }
  }
}
